<Window x:Class="OnePieceCardScanner.Views.InventoryWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Inventar"
        Height="700"
        Width="1200">

    <Grid Margin="20">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Inventar"
                   FontSize="28"
                   FontWeight="Bold"
                   Margin="0,0,0,20"/>

        <Grid Grid.Row="1">

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="280"/>
            </Grid.ColumnDefinitions>

            <DataGrid Grid.Column="0"
                      x:Name="InventoryGrid"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      SelectionChanged="InventoryGrid_SelectionChanged">

                <DataGrid.Columns>

                    <DataGridTextColumn Header="Inventar-ID"
                                        Binding="{Binding InventoryId}"
                                        Width="150"/>

                    <DataGridTextColumn Header="Kartennummer"
                                        Binding="{Binding CardNumber}"
                                        Width="120"/>

                    <DataGridTextColumn Header="Name"
                                        Binding="{Binding Name}"
                                        Width="250"/>

                    <DataGridTextColumn Header="Sprache"
                                        Binding="{Binding Language}"
                                        Width="90"/>

                    <DataGridTextColumn Header="Variante"
                                        Binding="{Binding Variant}"
                                        Width="120"/>

                    <DataGridTextColumn Header="Zustand"
                                        Binding="{Binding Condition}"
                                        Width="90"/>

                    <DataGridTextColumn Header="Status"
                                        Binding="{Binding Status}"
                                        Width="100"/>

                    <DataGridTextColumn Header="Lagerplatz"
                                        Binding="{Binding StorageCode}"
                                        Width="120"/>

                </DataGrid.Columns>

            </DataGrid>

            <Border Grid.Column="1"
                    Margin="20,0,0,0"
                    Padding="15"
                    BorderBrush="Gray"
                    BorderThickness="1"
                    CornerRadius="6">

                <Grid>

                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Image x:Name="CardPreviewImage"
                           Stretch="Uniform"
                           Margin="5"/>

                    <TextBlock Grid.Row="1"
                               x:Name="CardPreviewText"
                               Text="Keine Karte ausgewählt"
                               HorizontalAlignment="Center"
                               Margin="0,15,0,0"
                               Foreground="Gray"/>

                </Grid>

            </Border>

        </Grid>

    </Grid>

</Window>