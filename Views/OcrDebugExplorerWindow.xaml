<Window x:Class="OnePieceCardScanner.Views.OcrDebugExplorerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="OCR Debug Explorer"
        Width="1450"
        Height="900"
        MinWidth="1100"
        MinHeight="700"
        WindowStartupLocation="CenterOwner">

    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="250"/>
            <RowDefinition Height="240"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <DockPanel Grid.Row="0" LastChildFill="True" Margin="0,0,0,12">
            <Button Content="Bild öffnen" Width="120" Height="38" Margin="0,0,10,0"
                    DockPanel.Dock="Left" Click="OpenImage_Click"/>
            <Button x:Name="AnalyzeButton" Content="Analysieren" Width="120" Height="38"
                    Margin="0,0,12,0" DockPanel.Dock="Left" IsEnabled="False"
                    Click="Analyze_Click"/>
            <TextBox x:Name="ImagePathTextBox" Height="38"
                     VerticalContentAlignment="Center" IsReadOnly="True"/>
        </DockPanel>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="360"/>
            </Grid.ColumnDefinitions>

            <GroupBox Header="Originalbild">
                <Border Margin="8" Background="Black">
                    <Image x:Name="OriginalImage" Stretch="Uniform"/>
                </Border>
            </GroupBox>

            <GroupBox Grid.Column="2" Header="Ausgewählte Region">
                <Border Margin="8" Background="Black">
                    <Image x:Name="RegionImage" Stretch="Uniform"/>
                </Border>
            </GroupBox>

            <GroupBox Grid.Column="4" Header="Regionen">
                <Grid Margin="8">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <ComboBox x:Name="RegionComboBox" Height="32"
                              DisplayMemberPath="DisplayText"
                              SelectionChanged="RegionComboBox_SelectionChanged"/>
                    <TextBlock x:Name="RegionSummaryText" Grid.Row="1" Margin="0,10,0,0"
                               TextWrapping="Wrap"/>
                </Grid>
            </GroupBox>
        </Grid>

        <GroupBox Grid.Row="2" Header="Segmente" Margin="0,12,0,0">
            <ListBox x:Name="SegmentsList" BorderThickness="0" Background="Transparent"
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                     ScrollViewer.VerticalScrollBarVisibility="Auto"
                     SelectionChanged="SegmentsList_SelectionChanged">
                <ListBox.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel Orientation="Horizontal"/>
                    </ItemsPanelTemplate>
                </ListBox.ItemsPanel>
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Border Width="95" Height="145" Margin="5" Padding="5"
                                BorderBrush="#AAAAAA" BorderThickness="1" CornerRadius="5">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <TextBlock Text="{Binding Header}" HorizontalAlignment="Center"
                                           FontWeight="Bold"/>
                                <Border Grid.Row="1" Margin="0,4" Background="Black">
                                    <Image Source="{Binding Image}" Stretch="Uniform"/>
                                </Border>
                                <TextBlock Grid.Row="2" Text="{Binding BestText}"
                                           HorizontalAlignment="Center" FontWeight="SemiBold"/>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </GroupBox>

        <Grid Grid.Row="3" Margin="0,12,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="320"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <GroupBox Header="Ausgewähltes Segment">
                <Grid Margin="8">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Border Background="Black">
                        <Image x:Name="SelectedSegmentImage" Stretch="Uniform"/>
                    </Border>
                    <TextBlock x:Name="SelectedSegmentText" Grid.Row="1" Margin="0,8,0,0"
                               TextWrapping="Wrap"/>
                </Grid>
            </GroupBox>

            <GroupBox Grid.Column="2" Header="Top-5-Treffer">
                <ListBox x:Name="MatchesList" SelectionChanged="MatchesList_SelectionChanged">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Grid Margin="5">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="50"/>
                                    <ColumnDefinition Width="90"/>
                                    <ColumnDefinition Width="190"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="{Binding Rank}" FontWeight="Bold"/>
                                <TextBlock Grid.Column="1" Text="{Binding CharacterText}"
                                           FontSize="20" FontWeight="Bold"/>
                                <TextBlock Grid.Column="2" Text="{Binding ScoreText}"
                                           VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="3" Text="{Binding FileName}"
                                           TextTrimming="CharacterEllipsis"
                                           VerticalAlignment="Center"/>
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </GroupBox>
        </Grid>

        <DockPanel Grid.Row="4" Margin="0,12,0,0">
            <TextBlock x:Name="StatusText" Text="Bereit." VerticalAlignment="Center"
                       FontWeight="SemiBold"/>
            <StackPanel Orientation="Horizontal" DockPanel.Dock="Right"
                        HorizontalAlignment="Right">
                <TextBlock Text="Bestes Template:" Margin="15,0,8,0"
                           VerticalAlignment="Center"/>
                <Border Width="85" Height="70" Background="Black"
                        BorderBrush="#AAAAAA" BorderThickness="1">
                    <Image x:Name="BestTemplateImage" Stretch="Uniform"/>
                </Border>
            </StackPanel>
        </DockPanel>
    </Grid>
</Window>
