<Window x:Class="OnePieceCardScanner.Views.OcrBenchmarkProgressWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="OCR Benchmark"
        Width="620"
        Height="430"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Closing="Window_Closing">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="OCR Benchmark"
                   FontSize="27"
                   FontWeight="Bold"/>

        <StackPanel Grid.Row="1"
                    Margin="0,18,0,0">
            <StackPanel Margin="0,0,0,12">

                <TextBlock Text="Benchmark-Datenquelle"
               FontWeight="Bold"
               Margin="0,0,0,6"/>

                <ComboBox x:Name="BenchmarkModeComboBox"
              SelectedIndex="0"
              Width="320">

                    <ComboBoxItem>
                        Trainingsbilder
                    </ComboBoxItem>

                    <ComboBoxItem>
                        500 Preprocessed-Bilder
                    </ComboBoxItem>

                    <ComboBoxItem>
                        1000 Preprocessed-Bilder
                    </ComboBoxItem>

                    <ComboBoxItem>
                        Alle Preprocessed-Bilder
                    </ComboBoxItem>

                </ComboBox>

            </StackPanel>

            <TextBlock x:Name="CurrentCardText"
                       Text="Benchmark wird vorbereitet …"
                       FontSize="18"
                       FontWeight="SemiBold"/>

            <TextBlock x:Name="ProgressDetailText"
                       Text="0 / 0"
                       Margin="0,6,0,0"/>

            <ProgressBar x:Name="BenchmarkProgressBar"
                         Height="24"
                         Minimum="0"
                         Maximum="100"
                         Margin="0,10,0,0"/>
        </StackPanel>

        <Grid Grid.Row="2"
              Margin="0,18,0,0">

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <StackPanel>
                <TextBlock Text="Zwischenstand"
                           FontWeight="Bold"/>
                <TextBlock x:Name="ResultText"
                           Text="Richtig: 0&#x0a;Falsch: 0"
                           Margin="0,5,0,0"/>
            </StackPanel>

            <StackPanel Grid.Column="1">
                <TextBlock Text="Zeit"
                           FontWeight="Bold"/>
                <TextBlock x:Name="TimeText"
                           Text="Vergangen: 00:00:00&#x0a;Restzeit: wird berechnet"
                           Margin="0,5,0,0"/>
            </StackPanel>
        </Grid>

        <Border Grid.Row="3"
                Margin="0,18,0,0"
                Padding="12"
                Background="#F2F2F2"
                BorderBrush="#CCCCCC"
                BorderThickness="1"
                CornerRadius="5">

            <TextBlock x:Name="StatusText"
                       Text="Der Benchmark verwendet bevorzugt nur die manuell trainierten Bilder."
                       TextWrapping="Wrap"/>
        </Border>

        <StackPanel Grid.Row="4"
            Orientation="Horizontal"
            HorizontalAlignment="Right"
            Margin="0,18,0,0">

            <Button x:Name="StartButton"
            Content="Benchmark starten"
            Width="145"
            Height="38"
            Margin="0,0,10,0"
            Click="Start_Click"/>

            <Button x:Name="OpenReportButton"
            Content="Report öffnen"
            Width="125"
            Height="38"
            Margin="0,0,10,0"
            IsEnabled="False"
            Click="OpenReport_Click"/>

            <Button x:Name="CancelButton"
            Content="Schließen"
            Width="110"
            Height="38"
            Click="Cancel_Click"/>
        </StackPanel>
    </Grid>
</Window>
