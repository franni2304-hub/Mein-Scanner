<Window x:Class="OnePieceCardScanner.Views.TemplateViewerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="OCR Template Viewer"
        Width="1200"
        Height="800"
        MinWidth="900"
        MinHeight="600"
        WindowStartupLocation="CenterOwner">

    <Grid Margin="16">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0"
              Margin="0,0,0,12">

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel>
                <TextBlock Text="OCR Template Viewer"
                           FontSize="26"
                           FontWeight="Bold"/>

                <TextBlock x:Name="FolderText"
                           Text="-"
                           Foreground="Gray"
                           Margin="0,4,0,0"/>
            </StackPanel>

            <StackPanel Grid.Column="1"
                        Orientation="Horizontal"
                        VerticalAlignment="Center">

                <Button Content="Ordner öffnen"
                        Width="130"
                        Height="36"
                        Margin="4"
                        Click="OpenFolder_Click"/>

                <Button Content="Aktualisieren"
                        Width="130"
                        Height="36"
                        Margin="4"
                        Click="Refresh_Click"/>
            </StackPanel>
        </Grid>

        <Grid Grid.Row="1">

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="210"/>
                <ColumnDefinition Width="14"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Zeichenklassen -->
            <Border Grid.Column="0"
                    BorderBrush="#B0B0B0"
                    BorderThickness="1"
                    CornerRadius="6"
                    Padding="8">

                <DockPanel>
                    <TextBlock DockPanel.Dock="Top"
                               Text="Zeichen"
                               FontSize="18"
                               FontWeight="Bold"
                               Margin="4,2,4,8"/>

                    <ListBox x:Name="CharacterList"
                             SelectionChanged="CharacterList_SelectionChanged"/>
                </DockPanel>
            </Border>

            <!-- Templates -->
            <Border Grid.Column="2"
                    BorderBrush="#B0B0B0"
                    BorderThickness="1"
                    CornerRadius="6"
                    Padding="8">

                <DockPanel>
                    <TextBlock DockPanel.Dock="Top"
                               x:Name="SelectedCharacterText"
                               Text="Keine Zeichenklasse ausgewählt"
                               FontSize="18"
                               FontWeight="Bold"
                               Margin="4,2,4,8"/>

                    <ListBox x:Name="TemplateList"
                             BorderThickness="0"
                             Background="Transparent"
                             SelectionMode="Single"
                             MouseDoubleClick="TemplateList_MouseDoubleClick">
                        <ScrollViewer
                            HorizontalScrollBarVisibility="Disabled"
                            VerticalScrollBarVisibility="Auto"/>

                        <ListBox.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel Orientation="Horizontal"/>
                            </ItemsPanelTemplate>
                        </ListBox.ItemsPanel>

                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border Width="135"
                                        Height="155"
                                        Margin="6"
                                        Padding="6"
                                        BorderBrush="#C8C8C8"
                                        BorderThickness="1"
                                        CornerRadius="5"
                                        Background="#F7F7F7">

                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="*"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>

                                        <Image Source="{Binding Image}"
                                               Stretch="Uniform"
                                               Margin="2"/>

                                        <TextBlock Grid.Row="1"
                                                   Text="{Binding FileName}"
                                                   TextAlignment="Center"
                                                   TextTrimming="CharacterEllipsis"
                                                   Margin="2,6,2,0"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </DockPanel>
            </Border>
        </Grid>

        <Grid Grid.Row="2"
              Margin="0,12,0,0">

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <TextBlock x:Name="StatusText"
                       Text="Templates: 0"
                       VerticalAlignment="Center"
                       FontWeight="SemiBold"/>

            <Button Grid.Column="1"
                    Content="Ausgewähltes Template löschen"
                    Width="230"
                    Height="38"
                    Click="DeleteSelectedTemplate_Click"/>
        </Grid>
    </Grid>
</Window>