<Window x:Class="OnePieceCardScanner.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Void Century Vault"
        Height="900"
        Width="1450"
        MinHeight="750"
        MinWidth="1200"
        WindowStartupLocation="CenterScreen">

    <Grid Margin="20">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="260"/>
        </Grid.RowDefinitions>

        <!-- Kopfbereich -->
        <Grid Grid.Row="0"
              Margin="0,0,0,15">

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel>
                <TextBlock Text="Void Century Vault"
                           FontSize="28"
                           FontWeight="Bold"/>

                <TextBlock x:Name="DatabaseStatusText"
                           Text="Kartendatenbank wird geladen …"
                           Foreground="Gray"
                           Margin="0,4,0,0"/>
            </StackPanel>

            <StackPanel Grid.Column="1"
                        Orientation="Horizontal"
                        VerticalAlignment="Center">

                <TextBlock Text="Suche:"
                           VerticalAlignment="Center"
                           Margin="0,0,8,0"/>

                <TextBox x:Name="SearchTextBox"
                         Width="280"
                         Height="32"
                         VerticalContentAlignment="Center"/>
            </StackPanel>
        </Grid>

        <!-- Hauptbereich -->
        <Grid Grid.Row="1">

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="0.9*"/>
                <ColumnDefinition Width="20"/>
                <ColumnDefinition Width="1.3*"/>
            </Grid.ColumnDefinitions>

            <!-- Ausgewähltes Scannerbild -->
            <Border Grid.Column="0"
                    BorderBrush="#B0B0B0"
                    BorderThickness="1"
                    CornerRadius="8"
                    Background="#F4F4F4"
                    Padding="10">

                <Grid>
                    <TextBlock x:Name="PlaceholderText"
                               Text="Noch kein Scannerbild ausgewählt"
                               Foreground="Gray"
                               FontSize="18"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"/>

                    <Image x:Name="CardImage"
                           Stretch="Uniform"/>
                </Grid>
            </Border>

            <!-- Erkannte Karte -->
            <Border Grid.Column="2"
                    BorderBrush="#B0B0B0"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="18">

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Text="Erkannte Karte"
                               FontSize="22"
                               FontWeight="Bold"
                               Margin="0,0,0,15"/>

                    <Grid Grid.Row="1">

                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="420"/>
                            <ColumnDefinition Width="20"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Referenzbild -->
                        <Border Grid.Column="0"
                            BorderBrush="#D0D0D0"
                            BorderThickness="1"
                            CornerRadius="6"
                            Background="#F4F4F4"
                            Padding="8"
                            MinHeight="560">

                            <Grid>
                                <TextBlock x:Name="ReferencePlaceholderText"
                                           Text="Noch keine Karte erkannt"
                                           Foreground="Gray"
                                           TextAlignment="Center"
                                           TextWrapping="Wrap"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"/>

                                <Image x:Name="ReferenceCardImage"
                                       Stretch="Uniform"/>
                            </Grid>
                        </Border>

                        <!-- Kartendaten -->
                        <ScrollViewer Grid.Column="2"
                                      VerticalScrollBarVisibility="Auto">

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="135"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <TextBlock Grid.Row="0"
                                           Grid.ColumnSpan="2"
                                           x:Name="CardNameText"
                                           Text="-"
                                           FontSize="24"
                                           FontWeight="Bold"
                                           TextWrapping="Wrap"
                                           Margin="0,0,0,12"/>

                                <TextBlock Grid.Row="1"
                                           Grid.Column="0"
                                           Text="Kartennummer:"
                                           FontWeight="Bold"
                                           Margin="0,4"/>

                                <TextBlock Grid.Row="1"
                                           Grid.Column="1"
                                           x:Name="CardNumberText"
                                           Text="-"
                                           Margin="0,4"/>

                                <TextBlock Grid.Row="2"
                                           Grid.Column="0"
                                           Text="Sprache:"
                                           FontWeight="Bold"
                                           Margin="0,4"/>

                                <TextBlock Grid.Row="2"
                                           Grid.Column="1"
                                           x:Name="LanguageText"
                                           Text="-"
                                           Margin="0,4"/>

                                <TextBlock Grid.Row="3"
                                           Grid.Column="0"
                                           Text="Rarität:"
                                           FontWeight="Bold"
                                           Margin="0,4"/>

                                <TextBlock Grid.Row="3"
                                           Grid.Column="1"
                                           x:Name="RarityText"
                                           Text="-"
                                           Margin="0,4"/>

                                <TextBlock Grid.Row="4"
                                           Grid.Column="0"
                                           Text="Variante:"
                                           FontWeight="Bold"
                                           Margin="0,4"/>

                                <TextBlock Grid.Row="4"
                                           Grid.Column="1"
                                           x:Name="VariantText"
                                           Text="-"
                                           Margin="0,4"/>

                                <TextBlock Grid.Row="5"
                                           Grid.Column="0"
                                           Text="Kategorie:"
                                           FontWeight="Bold"
                                           Margin="0,4"/>

                                <TextBlock Grid.Row="5"
                                           Grid.Column="1"
                                           x:Name="CategoryText"
                                           Text="-"
                                           Margin="0,4"/>

                                <TextBlock Grid.Row="6"
                                           Grid.Column="0"
                                           Text="Farben:"
                                           FontWeight="Bold"
                                           Margin="0,4"/>

                                <TextBlock Grid.Row="6"
                                           Grid.Column="1"
                                           x:Name="ColorsText"
                                           Text="-"
                                           Margin="0,4"/>

                                <TextBlock Grid.Row="7"
                                           Grid.Column="0"
                                           Text="Kosten:"
                                           FontWeight="Bold"
                                           Margin="0,4"/>

                                <TextBlock Grid.Row="7"
                                           Grid.Column="1"
                                           x:Name="CostText"
                                           Text="-"
                                           Margin="0,4"/>

                                <TextBlock Grid.Row="8"
                                           Grid.Column="0"
                                           Text="Power:"
                                           FontWeight="Bold"
                                           Margin="0,4"/>

                                <TextBlock Grid.Row="8"
                                           Grid.Column="1"
                                           x:Name="PowerText"
                                           Text="-"
                                           Margin="0,4"/>

                                <TextBlock Grid.Row="9"
                                           Grid.Column="0"
                                           Text="Counter:"
                                           FontWeight="Bold"
                                           Margin="0,4"/>

                                <TextBlock Grid.Row="9"
                                           Grid.Column="1"
                                           x:Name="CounterText"
                                           Text="-"
                                           Margin="0,4"/>

                                <TextBlock Grid.Row="10"
                                           Grid.Column="0"
                                           Text="Erkennung:"
                                           FontWeight="Bold"
                                           Margin="0,4"/>

                                <TextBlock Grid.Row="10"
                                           Grid.Column="1"
                                           x:Name="ConfidenceText"
                                           Text="-"
                                           Margin="0,4"/>

                                <TextBlock Grid.Row="11"
                                           Grid.Column="0"
                                           Text="Zuordnung:"
                                           FontWeight="Bold"
                                           Margin="0,4"/>

                                <TextBlock Grid.Row="11"
                                           Grid.Column="1"
                                           x:Name="MatchStatusText"
                                           Text="-"
                                           TextWrapping="Wrap"
                                           Margin="0,4"/>
                            </Grid>
                        </ScrollViewer>
                    </Grid>
                </Grid>
            </Border>
        </Grid>

        <!-- Schaltflächen -->
        <WrapPanel Grid.Row="2"
                   HorizontalAlignment="Center"
                   Margin="0,18,0,18">

            <StackPanel Orientation="Horizontal"
            VerticalAlignment="Center"
            Margin="5">

                <Button Content="Bild auswählen"
            Width="150"
            Height="42"
            Click="SelectImage_Click"/>
                
                

                <CheckBox x:Name="AutoRecognizeCheckBox"
              Content="Bild direkt erkennen"
              Margin="12,0,0,0"
              VerticalAlignment="Center"
              IsChecked="False"/>
            </StackPanel>

            <Button Content="Bild entfernen"
                    Width="150"
                    Height="42"
                    Margin="5"
                    Click="RemoveImage_Click"/>

            <Button Content="Karte erkennen"
                    Width="150"
                    Height="42"
                    Margin="5"
                    FontWeight="Bold"
                    Click="RecognizeCard_Click"/>

            <Button Content="Ordner auswählen"
                    Width="150"
                    Height="42"
                    Margin="5"
                    Click="SelectFolder_Click"/>
            

            <Button Content="Inventar laden"
                    Width="150"
                    Height="42"
                    Margin="5"
                    Click="ShowInventory_Click"/>

            <Button Content="Inventar öffnen"
                    Width="150"
                    Height="42"
                    Margin="5"
                    Click="OpenInventory_Click"/>

            <Button Content="Test-ID erzeugen"
                    Width="150"
                    Height="42"
                    Margin="5"
                    Click="GenerateInventoryId_Click"/>

            <Button Content="OCR-Vorschau erzeugen"
                    Width="180"
                    Height="42"
                    Margin="5"
                    Click="GenerateOcrPreview_Click"/>      

            <Button Content="OCR-Templates erzeugen"
                    Width="180"
                    Height="42"
                    Margin="5"
                    Click="GenerateOcrTemplates_Click"/>

            <Button Content="OCR-Templates ansehen"
                    Width="180"
                    Height="42"
                    Margin="5"
                    Click="OpenTemplateViewer_Click"/>

            <Button Content="Segmentierung testen"
                    Width="180"
                    Height="42"
                    Margin="5"
                    Click="TestCharacterSegmentation_Click"/>
            <Button Content="OCR-Segmente trainieren"
                    Width="190"
                    Height="42"
                    Margin="5"
                    Click="OpenSegmentTraining_Click"/>
            <Button Content="OCR Templates analysieren"
                    Width="190"
                    Height="42"
                    Margin="5"
                    Click="OpenOcrTemplateAnalyzer_Click"/>
            <Button Content="OCR Benchmark starten"
                    Width="190"
                    Height="42"
                    Margin="5"
                    Click="RunOcrBenchmark_Click"/>
            <Button Content="OCR Debug Explorer"
                    Width="190"
                    Height="42"
                    Margin="5"
                    Click="OpenOcrDebugExplorer_Click"/>
        </WrapPanel>

        <!-- Batch-Import und Inventar -->
        <TabControl Grid.Row="3">

            <TabItem Header="Batch-Import">
                <ListBox x:Name="ImportList"
                         Margin="10"/>
            </TabItem>

            <TabItem Header="Inventar">
                <DataGrid x:Name="InventoryGrid"
                          Margin="10"
                          AutoGenerateColumns="False"
                          IsReadOnly="True">

                    <DataGrid.Columns>

                        <DataGridTextColumn Header="Inventar-ID"
                                            Binding="{Binding InventoryId}"
                                            Width="150"/>

                        <DataGridTextColumn Header="Kartennummer"
                                            Binding="{Binding CardNumber}"
                                            Width="130"/>

                        <DataGridTextColumn Header="Name"
                                            Binding="{Binding Name}"
                                            Width="*"/>

                        <DataGridTextColumn Header="Sprache"
                                            Binding="{Binding Language}"
                                            Width="90"/>

                        <DataGridTextColumn Header="Variante"
                                            Binding="{Binding Variant}"
                                            Width="120"/>

                        <DataGridTextColumn Header="Zustand"
                                            Binding="{Binding Condition}"
                                            Width="90"/>

                        <DataGridTextColumn Header="Status"
                                            Binding="{Binding Status}"
                                            Width="100"/>

                        <DataGridTextColumn Header="Lagerplatz"
                                            Binding="{Binding StorageCode}"
                                            Width="130"/>

                    </DataGrid.Columns>
                </DataGrid>
            </TabItem>
        </TabControl>
    </Grid>
</Window>